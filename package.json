{
  "name": "element-picker",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Chrome extension for selecting a page element and copying it as HTML, Markdown, or plain text.",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json,css,md,yml,yaml}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@types/turndown": "^5.0.6",
    "chrome-types": "^0.1.429",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  },
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
